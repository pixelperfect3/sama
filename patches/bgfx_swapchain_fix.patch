Fix Vulkan swapchain image count on Android devices

Modern Android devices (e.g., Pixel 9 with Mali GPU, Vulkan 1.3) request
minImageCount >= 5 from vkGetPhysicalDeviceSurfaceCapabilitiesKHR. bgfx
hardcodes NUM_SWAPCHAIN_IMAGE to 4, causing swapchain creation to fail
when vkGetSwapchainImagesKHR returns more images than the array can hold.
bgfx then silently falls back to OpenGL ES.

This patch:
1. Raises NUM_SWAPCHAIN_IMAGE from 4 to 8 (covers all known devices)
2. Makes it overridable via compile definition (#ifndef guard)
3. Adds a runtime check: if the device's minImageCount exceeds the array
   capacity, logs a clear warning before clamping

Tested on: Google Pixel 9 (Mali, Android 14, Vulkan 1.3)

--- a/src/renderer_vk.cpp
+++ b/src/renderer_vk.cpp
@@ -4235,7 +4235,14 @@
 			vkFreeCommandBuffers(m_device, m_commandPool, 1, &commandBuffer);
 		}

-#define NUM_SWAPCHAIN_IMAGE 4
+		// Maximum number of swapchain images the renderer can manage.
+		// Modern Android devices (e.g., Pixel 9 with Mali GPU) report
+		// minImageCount=5 from vkGetPhysicalDeviceSurfaceCapabilitiesKHR.
+		// The previous default of 4 caused Vulkan init to fail silently
+		// on these devices. Override at compile time if needed:
+		//   -DNUM_SWAPCHAIN_IMAGE=N
+#ifndef NUM_SWAPCHAIN_IMAGE
+#define NUM_SWAPCHAIN_IMAGE 8
+#endif // NUM_SWAPCHAIN_IMAGE
 		VkAllocationCallbacks*   m_allocatorCb;

--- a/src/renderer_vk.cpp  (createSwapchain minImageCount clamping)
+++ b/src/renderer_vk.cpp
@@ -2028,11 +2033,25 @@
 				compositeAlpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
 			}

+			// Determine the number of swapchain images to request.
+			// Use the device's minimum, but clamp to our array capacity.
+			uint32_t desiredImageCount = surfaceCapabilities.minImageCount;
+			if (surfaceCapabilities.maxImageCount > 0
+			&&  desiredImageCount > surfaceCapabilities.maxImageCount)
+			{
+				desiredImageCount = surfaceCapabilities.maxImageCount;
+			}
+			if (desiredImageCount > NUM_SWAPCHAIN_IMAGE)
+			{
+				BX_TRACE("Warning: device requires %d swapchain images but "
+					"NUM_SWAPCHAIN_IMAGE is %d. Clamping to %d. "
+					"Recompile with -DNUM_SWAPCHAIN_IMAGE=%d to fix."
+					, desiredImageCount
+					, NUM_SWAPCHAIN_IMAGE
+					, NUM_SWAPCHAIN_IMAGE
+					, desiredImageCount
+					);
+				desiredImageCount = NUM_SWAPCHAIN_IMAGE;
+			}
+
 			m_sci.sType = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR;
 			m_sci.pNext = NULL;
 			m_sci.flags = 0;
 			m_sci.surface = m_surface;
-			m_sci.minImageCount   = surfaceCapabilities.minImageCount;
+			m_sci.minImageCount   = desiredImageCount;
 			m_sci.imageFormat     = m_backBufferColorFormat.format;
