<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sama.engine">

    <!-- Vulkan 1.1 is the engine's minimum (bgfx + Android API 24+).
         The canonical Play Store filter pair is:
           android.hardware.vulkan.level    — feature level (1 = compute,
                                              maxImageDimension2D >= 8192,
                                              maxBoundDescriptorSets >= 8, …)
           android.hardware.vulkan.version  — packed VK API version, here
                                              0x00401000 = VK_API_VERSION_1_1.
         The bare `android.hardware.vulkan` name is non-canonical and may be
         missed by some Play Store device-eligibility filters. -->
    <uses-feature android:name="android.hardware.vulkan.level" android:version="1" android:required="true"/>
    <uses-feature android:name="android.hardware.vulkan.version" android:version="0x00401000" android:required="true"/>
    <uses-sdk android:minSdkVersion="24" android:targetSdkVersion="34"/>

    <application
        android:hasCode="false"
        android:label="Sama Engine"
        android:allowBackup="false">

        <activity
            android:name="android.app.NativeActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="unspecified"
            android:exported="true">

            <meta-data android:name="android.app.lib_name" android:value="sama_android"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
